{
  "name": "nested-if-then-else",
  "schema": {
    "type": "object",
    "if": { "properties": { "category": { "const": "vehicle" } } },
    "then": {
      "if": { "properties": { "engine": { "const": "electric" } } },
      "then": { "required": ["batteryCapacity"] },
      "else": { "required": ["fuelType"] }
    },
    "else": { "required": ["description"] }
  },
  "then": {
    "data": {
      "category": "vehicle",
      "engine": "electric"
    },
    "expectedInfo": {
      "name": "batteryCapacity"
    }
  },
  "else": {
    "data": {
      "category": "vehicle",
      "engine": "no-electric"
    },
    "expectedInfo": {
      "name": "fuelType"
    }
  }
}