{
  "name": "if-nested-value-using-required-then-enforce-deep-structure",
  "schema": {
    "if": {
      "properties": {
        "user": {
          "type": "object",
          "required": ["role"]
        }
      }
    },
    "then": {
      "properties": {
        "permissions": { "type": "array", "minItems": 1 }
      },
      "required": ["permissions"]
    },
    "else": {
      "properties": {
        "permissions": { "type": "array", "maxItems": 0 }
      },
      "required": ["permissions"]
    }
  },
  "then": {
    "data": {
      "user": { "role": "admin" },
      "permissions": []
    },
    "expectedInfo": {
      "type": "array",
      "name": "permissions",
      "currentValue": []
    }
  },
  "else": {
    "data": {
      "user": { "name": "admin" },
      "permissions": ["asd"]
    },
    "expectedInfo": {
      "type": "array",
      "name": "permissions",
      "currentValue": ["asd"]
    }
  }
}