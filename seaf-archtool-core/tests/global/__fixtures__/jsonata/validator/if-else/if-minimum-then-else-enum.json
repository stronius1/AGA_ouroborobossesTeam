{
  "name": "if-minimum-then-else-enum",
  "schema": {
    "if": {
      "properties": {
        "age": { "type": "number", "minimum": 18 }
      },
      "required": ["age"]
    },
    "then": {
      "properties": {
        "accessLevel": { "enum": ["adult", "vip"] }
      }
    },
    "else": {
      "properties": {
        "accessLevel": { "enum": ["child", "teen"] }
      }
    }
  },
  "then": {
    "data": {
      "age": 20,
      "accessLevel": "child"
    },
    "expectedInfo": { "name": "accessLevel", "currentValue": "child" }
  },
  "else": {
    "data": {
      "age": 10,
      "accessLevel": "aaa"
    },
    "expectedInfo": { "name": "accessLevel", "currentValue": "aaa" }
  }
}