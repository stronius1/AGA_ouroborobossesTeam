{
  "name": "simple-if-then-else",
  "schema": {
    "type": "object",
    "properties": {
      "type": { "type": "string" }
    },
    "if": {
      "properties": { "type": { "const": "A" } }
    },
    "then": {
      "properties": { "value": { "type": "number" } },
      "required": ["value"]
    },
    "else": {
      "properties": { "value": { "type": "string" } },
      "required": ["value"]
    }
  },
  "then": {
    "data": {
      "type": "A",
      "value": "wrong"
    },
    "expectedInfo": {
      "name": "value",
      "type": "number",
      "currentValue": "wrong"
    }
  },
  "else": {
    "data": {
      "type": "B",
      "value": 123
    },
    "expectedInfo": {
      "name": "value",
      "type": "string",
      "currentValue": 123
    }
  }
}