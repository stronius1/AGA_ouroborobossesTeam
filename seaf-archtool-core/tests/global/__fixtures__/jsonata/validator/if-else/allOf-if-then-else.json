{
  "name": "allOf-if-then-else.json",
  "schema": {
    "type": "object",
    "properties": {
      "autoSpeed": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "mode": {
                "type": "string",
                "title": "Режим работы",
                "enum": ["auto", "manual"]
              },
              "speed": {
                "type": "number",
                "title": "Скорость работы устройства"
              }
            }
          },
          {
            "if": {
              "properties": { "mode": { "const": "auto" } }
            },
            "then": {
              "properties": {
                "speed": { "minimum": 1 }
              },
              "required": ["speed"]
            },
            "else": {
              "properties": {
                "speed": { "maximum": 0 }
              }
            }
          }
        ]
      }
    }
  },
  "else": {
    "data": {
      "autoSpeed": {
        "mode": "manual",
        "speed": 12
      }
    },
    "expectedInfo": { "type": "number", "title": "Скорость работы устройства", "currentValue": 12, "name": "speed" }
  },
  "then": {
    "data": {
      "autoSpeed": {
        "mode": "auto",
        "speed": 0
      }
    },
    "expectedInfo": { "type": "number", "title": "Скорость работы устройства", "currentValue": 0, "name": "speed" }
  }
}