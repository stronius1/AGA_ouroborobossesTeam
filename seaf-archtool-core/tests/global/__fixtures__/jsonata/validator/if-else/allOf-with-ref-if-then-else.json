{
  "name": "allOf-with-ref-if-then-else.json",
  "schema": {
    "allOf": [
      {
        "if": {
          "properties": {
            "type": {
              "const": "person"
            }
          }
        },
        "then": {
          "$ref": "#/$defs/personRules"
        },
        "else": {
          "$ref": "#/$defs/companyRules"
        }
      }
    ],
    "$defs": {
      "personRules": {
        "properties": {
          "firstName": {
            "type": "string",
            "title": "Имя"
          },
          "lastName": {
            "type": "string",
            "title": "Фамилия"
          }
        },
        "required": [
          "firstName",
          "lastName"
        ]
      },
      "companyRules": {
        "properties": {
          "companyName": {
            "type": "string",
            "title": "Название компании"
          },
          "registrationId": {
            "type": "string",
            "title": "Id регистрации"
          }
        },
        "required": [
          "companyName",
          "registrationId"
        ]
      }
    }
  },
  "then": {
    "data": {"type": "person", "firstName": "Alice"},
    "expectedInfo": { "type": "string", "title": "Фамилия", "name": "lastName" }
  },
  "else": {
    "data": {"type": "no-person", "companyName": "ООО_ООО"},
    "expectedInfo": { "type": "string", "title": "Id регистрации", "name": "registrationId" }
  }
}