FROM python:3.12.7-slim-bookworm@sha256:60d9996b6a8a3689d36db740b49f4327be3be09a21122bd02fb8895abb38b50d

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

COPY debian-snapshot.sources /etc/apt/sources.list.d/debian.sources
RUN rm -f /etc/apt/sources.list \
    && apt-get update \
    && apt-get install --yes --no-install-recommends ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

RUN addgroup --system aga && adduser --system --ingroup aga --home /nonexistent aga

COPY requirements-container.txt ./requirements-container.txt
RUN python -m pip install --no-cache-dir --require-hashes --requirement requirements-container.txt

COPY VERSION ./VERSION
COPY rules ./rules
COPY tools ./tools
COPY scripts ./scripts

USER aga:aga
EXPOSE 8000

ENTRYPOINT ["python", "scripts/run_mcp.py"]
