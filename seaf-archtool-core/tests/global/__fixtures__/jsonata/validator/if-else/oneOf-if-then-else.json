{
  "name": "oneOf-if-then-else",
  "schema": {
    "oneOf": [
      {
        "if": { "properties": { "format": { "const": "json" } } },
        "then": { "properties": { "content": { "type": "object" } } },
        "else": { "properties": { "content": { "type": "string" } } }
      }
    ]
  },
  "then": {
    "data": {
      "format": "json",
      "content": "not object"
    },
    "expectedInfo": {
      "name": "content",
      "currentValue": "not object",
      "type": "object"
    }
  },
  "else": {
    "data": {
      "format": "no-json",
      "content": 123
    },
    "expectedInfo": {
      "name": "content",
      "currentValue": 123,
      "type": "string"
    }
  }
}