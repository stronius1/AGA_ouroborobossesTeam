{
  "name": "if-email-then-string-minLength-else-number",
  "schema": {
    "if": {
      "properties": {
        "contact": { "type": "string", "format": "email" }
      },
      "required": ["contact"]
    },
    "then": {
      "properties": {
        "note": { "type": "string", "minLength": 10 }
      },
      "required": ["note"]
    },
    "else": {
      "properties": {
        "note": { "type": "number" }
      },
      "required": ["note"]
    }
  },
  "then": {
    "data": {
      "contact": "user@example.com",
      "note": "short"
    },
    "expectedInfo": {
      "type": "string",
      "name": "note",
      "currentValue": "short"
    }
  },
  "else": {
    "data": {
      "contact": "nomail",
      "note": "not number"
    },
    "expectedInfo": {
      "type": "number",
      "name": "note",
      "currentValue": "not number"
    }
  }
}