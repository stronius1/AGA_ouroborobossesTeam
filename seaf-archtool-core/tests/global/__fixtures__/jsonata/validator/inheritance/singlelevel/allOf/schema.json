                "Не целевая"
              ]
            },
            "change-type": {
              "title": "Тип изменений",
              "enum": [
                "Планируется",
                "Разрабатывается",
                "Модифицируется",
                "Используется",
                "Выводится из эксплуатации"
              ]
            },
            "changes": {
              "title": "Описание изменений",
              "type": "string"
            }
