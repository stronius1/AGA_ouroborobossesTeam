{
  "name": "anyOf-if-then-else.json",
  "schema": {
    "anyOf": [
      {
        "if": {
          "properties": {
            "kind": {
              "const": "short"
            }
          }
        },
        "then": {
          "properties": {
            "length": {
              "type": "number",
              "title": "Длина",
              "maximum": 10
            }
          }
        },
        "else": {
          "properties": {
            "length": {
              "type": "number",
              "title": "Длина",
              "minimum": 11
            }
          }
        }
      }
    ]
  },
  "then": {
    "data": {
      "kind": "short",
      "length": 20
    },
    "expectedInfo": { "type": "number", "title": "Длина", "currentValue": 20, "name": "length" }
  },
  "else": {
    "data": {
      "kind": "no-short",
      "length": 10
    },
    "expectedInfo": { "type": "number", "title": "Длина", "currentValue": 10, "name": "length" }
  }
}