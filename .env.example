# Optional ArchTool GigaChat settings. They do not enable or prove an official
# GigaAgent E2E by themselves. Keep any real .env untracked.
GIGACHAT_CREDENTIAL=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=
GIGACHAT_BASE_URL=
GIGACHAT_DEFAULT_MODEL=GigaChat-2
GIGACHAT_TIMEOUT=600

# Optional TLS files are mounted/configured by the operator when required.
GIGACHAT_CA_BUNDLE_FILE=
GIGACHAT_CERT_FILE=
GIGACHAT_KEY_FILE=
