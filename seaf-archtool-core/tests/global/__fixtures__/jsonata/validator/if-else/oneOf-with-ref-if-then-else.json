{
  "name": "oneOf-with-ref-if-then-else",
  "schema": {
    "oneOf": [
      {
        "if": { "properties": { "mode": { "const": "online" } } },
        "then": { "$ref": "#/$defs/onlineRules" },
        "else": { "$ref": "#/$defs/offlineRules" }
      }
    ],
    "$defs": {
      "onlineRules": { "required": ["url"] },
      "offlineRules": { "required": ["address"] }
    }
  },
  "then": {
    "data": {
      "mode": "online"
    },
    "expectedInfo": {
      "name": "url"
    }
  },
  "else": {
    "data": {
      "mode": "no-online"
    },
    "expectedInfo": {
      "name": "address"
    }
  }
}