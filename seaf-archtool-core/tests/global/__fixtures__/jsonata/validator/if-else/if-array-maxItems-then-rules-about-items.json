{
  "name": "if-array-maxItems-then-rules-about-items",
  "schema": {
    "if": {
      "properties": {
        "items": {
          "type": "array",
          "maxItems": 2
        }
      },
      "required": ["items"]
    },
    "then": {
      "properties": {
        "priority": {
          "$comment": "Приоритет должен быть низким (low)",
          "const": "low"
        }
      },
      "required": ["priority"]
    },
    "else": {
      "properties": {
        "priority": {
          "$comment": "Приоритет должен быть высоким (high)",
          "const": "high"
        }
      },
      "required": ["priority"]
    }
  },
  "then": {
    "data": {
      "items": [1, 2],
      "priority": "high"
    },
    "expectedInfo": {
      "title": "Приоритет должен быть низким (low)", "name": "priority", "currentValue": "high"
    }
  },
  "else": {
    "data": {
      "items": [1, 2, 3],
      "priority": "low"
    },
    "expectedInfo": {
      "title": "Приоритет должен быть высоким (high)", "name": "priority", "currentValue": "low"
    }
  }
}